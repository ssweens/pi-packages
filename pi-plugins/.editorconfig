root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.{js,ts}]
indent_size = 2
max_line_length = 100

[*.json]
indent_size = 2

[*.md]
max_line_length = off

[*.sh]
end_of_line = lf
indent_size = 4

[*.{yaml,yml}]
indent_size = 2
max_line_length = off
