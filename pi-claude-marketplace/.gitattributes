* text auto

# shell scripts
*.sh text eol=lf

# large binary assets stored with Git LFS
*.gif filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.webp filter=lfs diff=lfs merge=lfs -text

# hash-stability fixtures: treat as binary so git does NOT normalize line
# endings (CRLF/LF) or BOM bytes. The whole point of these fixtures is to
# round-trip byte-for-byte through clone/checkout so the PI-7 snapshot
# hash stays stable across platforms.
tests/domain/fixtures/hash-stability/** -text
